<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <!-- Plugin manifest -->
  <PropertyGroup>
    <Name>Snapper</Name>
    <Version>0.5.2.6</Version>
    <Author>Eqbot, Vivi, astrodoobs, BeSlightly</Author>
    <RepoUrl>https://github.com/NeXzRo/Snappy</RepoUrl>
    <Punchline>Plugin to save current appearance and applied mods of a character</Punchline>
    <Description>Want to export your character and mods exactly as-is in a single collection *without* Mare? This plugin saves and loads your character's current appearance, and allows you to share modded characters without relying on MCDF.</Description>
    <Tags>snappy, snapper, utility, mare, snapshot</Tags>
  </PropertyGroup>

  <!-- Build settings -->
  <PropertyGroup>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <!-- Project references -->
  <ItemGroup>
    <ProjectReference Include="..\Glamourer.Api\Glamourer.Api.csproj" />
    <ProjectReference Include="..\Penumbra\Penumbra.GameData\Penumbra.GameData.csproj" />
    <ProjectReference Include="..\Penumbra\Penumbra\Penumbra.csproj" />
  </ItemGroup>

  <!-- NuGet -->
  <ItemGroup>
    <PackageReference Include="ECommons" Version="3.2.1.15" />
    <PackageReference Include="lz4net" Version="1.0.15.93" />
  </ItemGroup>

  <!-- Keep Penumbra's unrelated runtime dependencies out of the release zip. -->
  <Target Name="PruneUnusedPenumbraRuntimeFiles"
          BeforeTargets="DefaultDalamudPackagerRelease"
          Condition="'$(Configuration)' == 'Release'">
    <ItemGroup>
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)SharpCompress.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)SixLabors.ImageSharp.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)DirectXTexC.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)SharpGLTF.Core.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)SharpGLTF.Runtime.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)SharpGLTF.Toolkit.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)LiteDB.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)EmbedIO.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)Swan.Lite.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)PeNet.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)System.Security.Cryptography.Pkcs.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)runtimes\**\System.Security.Cryptography.Pkcs.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)OtterTex.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)Penumbra.CrashHandler.exe" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)Penumbra.CrashHandler.dll" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)Penumbra.CrashHandler.deps.json" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)Penumbra.CrashHandler.runtimeconfig.json" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)Penumbra.json" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)tsmLogo.png" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)Penumbra.Api.xml" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)Penumbra.String.xml" />
      <_UnusedPenumbraRuntimeFile Include="$(OutputPath)Glamourer.Api.xml" />
    </ItemGroup>

    <Delete Files="@(_UnusedPenumbraRuntimeFile)" />
  </Target>
</Project>
